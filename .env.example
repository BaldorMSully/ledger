# Copy to .env (local dev) or set these as real secrets in your deployment environment.
# Never commit a filled-in .env — it's gitignored by default, keep it that way.

DATABASE_URL="postgresql://ledger:ledger@localhost:5432/ledger?schema=public"

# Generate with: npx auth secret
AUTH_SECRET=""

# Google OAuth client — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated emails allowed to sign in — exactly the household's members
ALLOWED_HOUSEHOLD_EMAILS=""

AUTH_URL="http://localhost:3000"
