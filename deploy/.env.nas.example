# Copy to deploy/.env on the NAS (never commit the filled-in version, chmod 600 it).
# POSTGRES_PASSWORD / the password embedded in DATABASE_URL / PGPASSWORD must all be the
# SAME value — the app, the db container, and the backup job all authenticate with it.

POSTGRES_PASSWORD="generate-a-real-password-here"
PGPASSWORD="generate-a-real-password-here"

DATABASE_URL="postgresql://ledger:generate-a-real-password-here@db:5432/ledger?schema=public"
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
ALLOWED_HOUSEHOLD_EMAILS=""
AUTH_URL="https://ledger.mikesullivan.dev"

# Optional but recommended: a healthchecks.io check URL for the nightly backup.
# The backup script pings it on success (and <url>/fail on failure) — healthchecks
# alerts you when the ping DOESN'T arrive, which also catches a cron that never runs.
# Left empty, the script posts successes to the ntfy topic instead.
HEALTHCHECK_URL=""
